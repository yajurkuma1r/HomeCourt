APP_URL=http://localhost:5174
NOTIFICATION_TIME_ZONE=Asia/Kolkata
NOTIFICATION_LOOKBACK_MS=604800000

# Production database. Leave empty locally to use server/data/auth-db.json.
DATABASE_URL=
PGSSLMODE=require

# TomTom Maps API key for the frontend map.
VITE_TOMTOM_API_KEY=

# Render backend URL for deployed frontend. Leave empty locally to use Vite proxy.
VITE_API_URL=

# SMTP settings used by the backend notification worker.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true,
# SMTP_USER=your@gmail.com, SMTP_PASS=your-app-password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
